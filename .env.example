# ═══════════════════════════════════════════════════════════════════
# Builddy — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════

# ── Backend: GLM API ──────────────────────────────────────────────
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-5.1
GLM_FAST_MODEL=glm-4.5
GLM_FALLBACK_MODEL=glm-5
GLM_VISION_MODEL=glm-5v-turbo
GLM_IMAGE_MODEL=cogView-4-250304
ENABLE_THINKING=true
ENABLE_WEB_SEARCH=true
ENABLE_IMAGE_GEN=true

# ── Backend: Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./builddy.db

# ── Backend: App Settings ─────────────────────────────────────────
MAX_STEPS=30
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]

# ── Backend: Cloud Deploy (optional) ──────────────────────────────
RAILWAY_API_TOKEN=
GITHUB_TOKEN=
GITHUB_ORG=builddy-apps

# ── Backend: Twitter Scraper (Playwright-based, no paid API) ──────
ENABLE_TWITTER_SCRAPER=true

# ── Backend: Twitter/X API (optional, for posting replies) ────────
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Frontend: API Connection ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Frontend: Auth0 Configuration ─────────────────────────────────
AUTH0_SECRET=generate_a_random_32_byte_hex_string
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
