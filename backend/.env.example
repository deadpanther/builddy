GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-5.1
GLM_VISION_MODEL=glm-5v-turbo
GLM_IMAGE_MODEL=cogView-4-250304
ENABLE_THINKING=true
ENABLE_WEB_SEARCH=true
ENABLE_IMAGE_GEN=true
DATABASE_URL=sqlite:///./builddy.db
MAX_STEPS=30
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]

# Cloud Deploy (optional — needed for one-click cloud deploy)
RAILWAY_API_TOKEN=
GITHUB_TOKEN=
GITHUB_ORG=builddy-apps

# Twitter Scraper (Playwright-based — no paid API needed)
ENABLE_TWITTER_SCRAPER=true

# Twitter/X API (optional — used for posting replies)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
