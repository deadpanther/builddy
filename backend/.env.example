# ── Required ──────────────────────────────────────────────────────
GLM_API_KEY=your_glm_api_key_here

# ── GLM API ──────────────────────────────────────────────────────
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-5.1
GLM_FAST_MODEL=glm-4.5
GLM_FALLBACK_MODEL=glm-5
GLM_VISION_MODEL=glm-5v-turbo
GLM_IMAGE_MODEL=cogView-4-250304

# ── Feature Flags ────────────────────────────────────────────────
ENABLE_THINKING=true
ENABLE_WEB_SEARCH=true
ENABLE_IMAGE_GEN=true
ENABLE_AUTOPILOT=true
ENABLE_AUTO_TEST_GEN=true

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./buildy.db

# ── Twitter Integration (optional) ──────────────────────────────
ENABLE_TWITTER_SCRAPER=false
# TWITTER_BEARER_TOKEN=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# ── Cloud Deploy (optional) ─────────────────────────────────────
# RAILWAY_API_TOKEN=
# GITHUB_TOKEN=
# GITHUB_ORG=builddy-apps

# ── App Settings ─────────────────────────────────────────────────
MAX_STEPS=30
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
